# Supabase — valores default apontam para a stack local do `supabase start`.
# Pegue a anon key real rodando `supabase status` após `supabase start`.
# Staging/prod são configurados no Vercel (Preview/Production).
VITE_SUPABASE_URL=http://127.0.0.1:54321
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Sentry — deixe VAZIO em dev local (gate por import.meta.env.PROD).
# Configure no Vercel (DSNs separadas para Preview e Production).
VITE_SENTRY_DSN=
VITE_APP_ENV=development
# Release tag para Sentry — em Vercel, injete VERCEL_GIT_COMMIT_SHA como VITE_RELEASE.
# Deixar vazio em dev local; Sentry usará "dev" como fallback.
VITE_RELEASE=
